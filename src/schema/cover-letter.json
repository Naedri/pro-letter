{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://example.com/example.json",
  "title": "Cover Letter Schema",
  "description": "Schema representing a job application cover letter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "applicant",
    "recipient",
    "position",
    "subject",
    "content",
    "metadata"
  ],
  "properties": {
    "applicant": {
      "type": "object",
      "required": ["firstName", "lastName", "email"],
      "additionalProperties": false,
      "properties": {
        "firstName": {
          "type": "string",
          "minLength": 1
        },
        "lastName": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "title": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "address": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "street": { "type": "string" },
            "city": { "type": "string" },
            "postalCode": { "type": "string" },
            "country": { "type": "string" }
          }
        },
        "linkedIn": {
          "type": "string",
          "format": "uri"
        },
        "website": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "recipient": {
      "type": "object",
      "required": ["companyName"],
      "additionalProperties": false,
      "properties": {
        "companyName": {
          "type": "string",
          "minLength": 1
        },
        "hiringManagerName": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "department": {
          "type": "string"
        },
        "address": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "street": { "type": "string" },
            "city": { "type": "string" },
            "postalCode": { "type": "string" },
            "country": { "type": "string" }
          }
        }
      }
    },
    "position": {
      "type": "object",
      "required": ["title"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "reference": {
          "type": "string"
        },
        "location": {
          "type": "string"
        }
      }
    },
    "properties": {
      "subject": {
        "type": "string",
        "minLength": 1,
        "description": "Subject line of the cover letter (e.g. Application for Software Engineer - Ref 1234)"
      }
    },
    "content": {
      "type": "object",
      "required": ["opening", "body", "closing"],
      "additionalProperties": false,
      "properties": {
        "opening": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "closing": {
          "type": "string",
          "minLength": 1
        },
        "signature": {
          "type": "string"
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["date"],
      "additionalProperties": false,
      "properties": {
        "date": {
          "type": "string",
          "format": "date"
        },
        "language": {
          "type": "string",
          "default": "en"
        },
        "version": {
          "type": "string",
          "default": "1.0.0"
        }
      }
    }
  }
}
